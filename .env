# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS=credentials.json
TIMEZONE=America/Sao_Paulo
REMINDER_MINUTES=30

# Twilio (obtenha em https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=seu_account_sid  # Ex: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu_auth_token    # Ex: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=seu_numero   # Ex: +14155238886 (número do sandbox) 