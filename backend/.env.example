# Configurações do banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/meetingdb

# Configurações do Redis
REDIS_URL=redis://localhost:6379

# Configurações de segurança
SECRET_KEY=chave_secreta_para_jwt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Configurações do OpenAI Whisper
WHISPER_MODEL_SIZE=medium  # tiny, base, small, medium, large

# Configurações do RD Station
RD_STATION_API_KEY=sua_chave_api_rdstation

# Configurações do Zoom
ZOOM_API_KEY=sua_chave_api_zoom
ZOOM_API_SECRET=seu_segredo_api_zoom

# Configurações do Google Meet
GOOGLE_CREDENTIALS_FILE=caminho_para_credenciais.json

# Configurações do Microsoft Teams
MS_TEAMS_CLIENT_ID=seu_client_id_ms_teams
MS_TEAMS_CLIENT_SECRET=seu_client_secret_ms_teams

# Configurações do servidor
HOST=0.0.0.0
PORT=8000
DEBUG=True 